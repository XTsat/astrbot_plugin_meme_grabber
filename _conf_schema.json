{
    "temp_dir": {
        "description": "临时文件保存目录",
        "type": "string",
        "default": "data/plugin_data/astrbot_plugin_meme_grabber"
    },
    "delete_after_send": {
        "description": "发送后删除临时文件",
        "type": "bool",
        "default": true,
        "hint": "注意:开启时，也会在插件重载后立即删除所有临时文件"
    },
    "default_extension": {
        "description": "默认表情包扩展名",
        "type": "string",
        "default": "jpg",
        "hint": "当无法检测表情包类型时使用的默认扩展名"
    },
    "download_timeout": {
        "description": "表情包下载超时时间（秒）",
        "type": "int",
        "default": 60
    },
    "send_method": {
        "description": "发送方式",
        "type": "string",
        "default": "image",
        "hint": "选择发送静态表情包的方式，动图将以群文件方式发送保留动画",
        "options": ["file", "image"],
        "labels": ["群文件方式", "图片方式"]
    },
    "filename_pattern": {
        "description": "自定义文件命名规则",
        "type": "string",
        "default": "meme_{date}_{timestamp}",
        "hint": "可用规则: {date}日期, {time}时间, {timestamp}时间戳, {uuid}随机ID, {datetime:自定义日期格式}可用：%Y %m %d %H %M %S，扩展名自动追加"
    },
    "list_mode": {
        "description": "群名单模式",
        "type": "string",
        "default": "blacklist",
        "hint": "黑名单模式：名单内群聊禁止使用；白名单模式：仅名单内群聊允许使用",
        "options": ["disabled", "blacklist", "whitelist"],
        "labels": ["禁用（不限制）", "黑名单模式", "白名单模式"]
    },
    "group_list": {
        "description": "群号列表（每行一个）",
        "type": "text",
        "default": "",
        "hint": "每行填写一个群号，与名单模式配合使用"
    }
}


